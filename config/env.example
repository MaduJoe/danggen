# 당근마켓 E2E 테스트 환경 변수 설정 예시
# 실제 사용 시 프로젝트 루트에 .env 파일로 복사하여 사용하세요

# API 환경 설정
API_ENVIRONMENT=development
API_VERSION=v1
API_BASE_URL=https://dev-api.daangn.com/api/v1

# API 인증 정보
DAANGN_API_KEY=your_api_key_here
DAANGN_CLIENT_ID=your_client_id_here
DAANGN_CLIENT_SECRET=your_client_secret_here

# API 요청 설정
API_TIMEOUT=30
API_MAX_RETRIES=3
API_RETRY_DELAY=1.0

# 로깅 설정
LOG_LEVEL=INFO
LOG_REQUESTS=true
LOG_RESPONSES=false

# 디버그 모드
DEBUG_MODE=true

# 모바일 자동화 설정
APPIUM_SERVER_URL=http://localhost:4723
ANDROID_HOME=C:/Users/YourUser/AppData/Local/Android/Sdk
DEVICE_NAME=Android Emulator
PLATFORM_VERSION=11.0

# 당근마켓 앱 설정
APP_PACKAGE=com.towneers.www
APP_ACTIVITY=.SplashActivity
APP_PATH=/path/to/daangn.apk

# 테스트 데이터 설정
TEST_DATA_DIR=test_data
SCREENSHOT_DIR=screenshots
REPORTS_DIR=reports

# 테스트 사용자 설정 (옵션)
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=TestPassword123!
TEST_USER_PHONE=010-1234-5678

# 위치 설정
DEFAULT_LOCATION_LAT=37.5326
DEFAULT_LOCATION_LNG=127.024612
DEFAULT_LOCATION_NAME=용산구
